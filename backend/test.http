// Create a new user with a USER role
POST http://localhost:5000/user-api/users
Content-Type: application/json

{
    "firstName": "Anand",
    "lastName": "Kumar",
    "email": "23eg105b51@anurag.edu.in",
    "password": "anand123",
    "profileImageUrl": "https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_960_720.png"
}

