###
// Login as the created user role to get a JWT token
POST http://localhost:5000/common-api/login
Content-Type: application/json

{
    "password": "1234",
    "email": "testing10@gmail.com"
}

###
// Login as the created author role to get a JWT token
POST http://localhost:5000/common-api/login
Content-Type: application/json

{
    "password": "1234",
    "email": "testing11@gmail.com"
}

###
// Login as the created admin role to get a JWT token
POST http://localhost:5000/common-api/login
Content-Type: application/json

{
    "password": "admin",
    "email": "admin@gmail.com"
}

###
// Create a new article as an AUTHOR (replace <JWT_TOKEN> with the token obtained from the previous step)
POST http://localhost:5000/author-api/articles
Content-Type: application/json

{
    "author" : "69afe867c40dd5d5d78702da",
    "title": "Hello World",
    "content": "This is the content of my first article.",
    "category": "Technology"
}

// Get the article by author
###
GET http://localhost:5000/author-api/articles/6989663bf620ae5d19bed315

###
//Update the article
PUT http://localhost:5000/author-api/articles
Content-Type: application/json

{
    "author" : "6989663bf620ae5d19bed315",
    "articleId": "698974374ec738758611c2e7",
    "title": "My Updated Article",
    "content": "This is the updated content of my article.",
    "category": "Science"
}

###
//logout
GET http://localhost:5000/common-api/logout

###
POST http://localhost:5000/user-api/comments
Content-Type: application/json

{
    "articleId": "69897505b3709d2748d57f6d",
    "user": "6989798d09520f8cd85dcf7f",
    "comment": "Great article! Very informative."
}

